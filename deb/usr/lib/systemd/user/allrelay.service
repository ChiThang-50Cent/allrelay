[Unit]
Description=AllRelay - Android Phone Media Stream Server
After=pipewire.service pipewire-pulse.service

[Service]
Type=simple
ExecStartPre=/usr/bin/mkdir -p %t/allrelay
ExecStartPre=/usr/bin/mkdir -p %h/.local/state/allrelay
ExecStartPre=/usr/bin/rm -f %t/allrelay/url
ExecStart=/usr/bin/allrelay-server --web-host 127.0.0.1 --web-port 0 --web-url-file %t/allrelay/url --log-file %h/.local/state/allrelay/remote.log --log-file-max-bytes 10485760 -v
ExecStopPost=/usr/bin/rm -f %t/allrelay/url
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
